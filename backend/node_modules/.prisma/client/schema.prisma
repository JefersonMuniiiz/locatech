generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                 String   @id @default(cuid())
  name               String
  document           String   @unique
  email              String   @unique
  phone              String?
  address            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  lastContractNumber Int      @default(0)

  users      User[]
  clients    Client[]
  equipments Equipment[]
  rentals    Rental[]
  expenses   Expense[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(OPERATOR)
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String
  document  String
  email     String?
  address   String
  city      String
  state     String
  zipCode   String?
  notes     String?
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company  @relation(fields: [companyId], references: [id])
  rentals Rental[]
}

model Equipment {
  id                String          @id @default(cuid())
  name              String
  type              EquipmentType
  totalQuantity     Int
  availableQuantity Int
  dailyRate         Decimal         @db.Decimal(10, 2)
  status            EquipmentStatus @default(AVAILABLE)
  description       String?
  serialNumber      String?
  companyId         String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  company     Company      @relation(fields: [companyId], references: [id])
  rentalItems RentalItem[]
  damageFines DamageFine[]
}

model Rental {
  id              String       @id @default(cuid())
  clientId        String
  companyId       String
  startDate       DateTime
  endDate         DateTime
  returnDate      DateTime?
  totalDays       Int
  totalAmount     Decimal      @db.Decimal(10, 2)
  discountPercent Float        @default(0)
  discountAmount  Decimal      @default(0) @db.Decimal(10, 2)
  fineAmount      Decimal      @default(0) @db.Decimal(10, 2)
  status          RentalStatus @default(ACTIVE)
  notes           String?
  address         String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  contractNumber  Int          @default(0)

  client      Client       @relation(fields: [clientId], references: [id])
  company     Company      @relation(fields: [companyId], references: [id])
  items       RentalItem[]
  payment     Payment?
  damageFines DamageFine[]
}

model RentalItem {
  id          String  @id @default(cuid())
  rentalId    String
  equipmentId String
  quantity    Int
  dailyRate   Decimal @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)

  rental    Rental    @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id])
}

model Payment {
  id           String         @id @default(cuid())
  rentalId     String         @unique
  amount       Decimal        @db.Decimal(10, 2)
  fineAmount   Decimal        @default(0) @db.Decimal(10, 2)
  damageAmount Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount  Decimal        @db.Decimal(10, 2)
  status       PaymentStatus  @default(PENDING)
  paidAt       DateTime?
  method       PaymentMethod?
  notes        String?
  // Asaas integration
  asaasId      String?
  asaasStatus  String?
  invoiceUrl   String?
  bankSlipUrl  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  rental Rental @relation(fields: [rentalId], references: [id])
}

model DamageFine {
  id          String   @id @default(cuid())
  rentalId    String
  equipmentId String?
  description String
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  rental    Rental     @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  equipment Equipment? @relation(fields: [equipmentId], references: [id])
}

model Expense {
  id          String          @id @default(cuid())
  companyId   String
  description String
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(10, 2)
  paidAt      DateTime
  method      PaymentMethod?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

enum Role {
  ADMIN
  OPERATOR
}

enum EquipmentType {
  SCAFFOLD
  PROP
  CONCRETE_MIXER
  MACHINE
  TOOL
  OTHER
}

enum EquipmentStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
}

enum RentalStatus {
  ACTIVE
  COMPLETED
  DELAYED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  BOLETO
}

enum ExpenseCategory {
  MAINTENANCE
  FUEL
  SALARY
  RENT
  SUPPLIES
  TRANSPORT
  TAX
  OTHER
}
